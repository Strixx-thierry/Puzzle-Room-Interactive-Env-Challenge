  m_EditorClassIdentifier: Assembly-CSharp::ChapterClue
  infoPanel: {fileID: 1914681051}
  chapterTitle: 'Chapter 4 : The Decision'
  chapterText: "I sat in this chair for the last time on the 9th. By then the device
    was armed\r\n built to erase the work, the room, and whoever came searching.
    There is a way\r\nto disarm it. The combination is this story, read in order:
    four numbers, one\r\nfrom each confession. You have held them all along.  Dr.
    A."
  puzzleManager: {fileID: 962960528}
  puzzleIndex: 3
  requirePreviousChapter: 1
  lockedTitle: "Not yet\u2026"
  lockedMessage: There are earlier pages you haven't read. Piece the story together
    in order first.
  unlockNext: {fileID: 994450565}
  onRevealed:
    m_PersistentCalls:
      m_Calls: []
