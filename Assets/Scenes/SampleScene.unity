  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::ChapterClue
  infoPanel: {fileID: 1914681051}
  chapterTitle: 'Chapter 1 : The Confession'
  chapterText: 'If you are reading this, you cracked the safe  so you are as stubborn
    as I was.

    My name no longer matters; the work does. For years I built something
    that

    should never have existed. On the night of the 4th, I finally understood
    what

    I had made and that it could never leave this room. Dr. A.'
  puzzleManager: {fileID: 962960528}
  puzzleIndex: 0
  requirePreviousChapter: 1
  lockedTitle: "Not yet\u2026"
  lockedMessage: There are earlier pages you haven't read. Piece the story together
    in order first.
